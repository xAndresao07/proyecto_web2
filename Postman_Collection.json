{
  "info": {
    "name": "EmparejaTech API - Proyecto Web II (H3)",
    "description": "Colección para la API de Optimización Técnica (ULEAM). Incluye Auth y los 3 módulos: Técnicos, Solicitantes e Intervenciones.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "tecnico_id", "value": "1", "type": "string" },
    { "key": "solicitante_id", "value": "1", "type": "string" },
    { "key": "dispositivo_id", "value": "1", "type": "string" },
    { "key": "ticket_id", "value": "1", "type": "string" },
    { "key": "cita_id", "value": "1", "type": "string" },
    { "key": "punto_id", "value": "1", "type": "string" },
    { "key": "soporte_id", "value": "1", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tecnico1@uleam.edu.ec\",\n  \"password\": \"claveSegura123\",\n  \"rol\": \"tecnico\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/registrar", "host": ["{{base_url}}"], "path": ["auth", "registrar"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tecnico1@uleam.edu.ec\",\n  \"password\": \"claveSegura123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Técnicos (Anthony Solórzano)",
      "item": [
        {
          "name": "Listar técnicos",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/tecnicos", "host": ["{{base_url}}"], "path": ["tecnicos"] } }
        },
        {
          "name": "Crear técnico",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos Zambrano\",\n  \"reputacion\": 4.8,\n  \"servicios\": [\n    { \"nombre_servicio\": \"Instalación de SO\", \"nivel_experiencia\": \"avanzado\", \"tiempo_estimado\": \"45min\" }\n  ],\n  \"horarios\": [\n    { \"dia_semana\": \"martes\", \"hora_inicio\": \"14:00\", \"hora_fin\": \"16:00\", \"estado_disponibilidad\": \"libre\" }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/tecnicos", "host": ["{{base_url}}"], "path": ["tecnicos"] }
          }
        },
        {
          "name": "Obtener técnico por ID",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/tecnicos/{{tecnico_id}}", "host": ["{{base_url}}"], "path": ["tecnicos", "{{tecnico_id}}"] } }
        },
        {
          "name": "Actualizar técnico",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Carlos Zambrano\",\n  \"reputacion\": 5.0\n}" },
            "url": { "raw": "{{base_url}}/tecnicos/{{tecnico_id}}", "host": ["{{base_url}}"], "path": ["tecnicos", "{{tecnico_id}}"] }
          }
        },
        {
          "name": "Borrar técnico",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/tecnicos/{{tecnico_id}}", "host": ["{{base_url}}"], "path": ["tecnicos", "{{tecnico_id}}"] } }
        }
      ]
    },
    {
      "name": "Solicitantes (Jandry Cedeño)",
