            "url": { "raw": "{{base_url}}/tickets/{{ticket_id}}", "host": ["{{base_url}}"], "path": ["tickets", "{{ticket_id}}"] }
          }
        },
        {
          "name": "Borrar ticket",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/tickets/{{ticket_id}}", "host": ["{{base_url}}"], "path": ["tickets", "{{ticket_id}}"] } }
        }
      ]
    },
    {
      "name": "Intervenciones (Mario Soriano)",
      "item": [
