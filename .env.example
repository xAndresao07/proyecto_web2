# Configuracion de la API de Tecnicos.
# Copia este archivo a .env y ajusta los valores: cp .env.example .env
# El archivo .env NO se sube a Git (esta en .gitignore).

# Puerto HTTP en el que escucha el servidor.
PUERTO=:8080

# Motor de base de datos: "sqlite" (por defecto, desarrollo local) o "postgres".
DB_DRIVER=sqlite

# DSN de PostgreSQL. SOLO se usa si DB_DRIVER=postgres (en Docker se inyecta por
# docker-compose.yml).
# Ejemplo:
# DB_DSN=host=localhost user=tecnicos password=tecnicos dbname=tecnicos port=5432 sslmode=disable
DB_DSN=

# Archivo SQLite de la base de datos (solo se usa si DB_DRIVER=sqlite).
RUTA_DB=proyecto.db

# Backend de productos/categorias: "gorm" (por defecto) o "sqlc".
STORAGE=sqlc

# Clave para firmar los JWT.
# EN PRODUCCION usa un valor largo, aleatorio y secreto.
JWT_SECRETO=anthol34

# Validez del token (formato de duracion de Go: 24h, 30m, 1h30m...).
JWT_DURACION=24h

# Timeouts del servidor HTTP (formato de duracion de Go).
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s